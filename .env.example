# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/nxtlvl

# Admin (seed script uchun)
ADMIN_EMAIL=admin@nxtlvl.uz
ADMIN_PASSWORD=your-secure-password
# Login sahifasida email/parolni nusxalash kartasi (true = ko'rsatish)
SHOW_ADMIN_LOGIN_HINT=true

# JWT
JWT_SECRET=your-random-32-char-secret

# Cloudinary (Dashboard → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public site URL (optional, for absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
